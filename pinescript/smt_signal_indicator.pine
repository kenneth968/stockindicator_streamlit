// https://mozilla.org/MPL/2.0/
// SMT A+ Signal System — ICT/SMC Style
// FVG, IFVG, Liquidity Sweeps, Order Blocks, HTF Bias, SMT Divergence, Session Filter, A+ Scoring

//@version=6
indicator("SMT A+ Signal System", overlay=true, max_labels_count=500, max_boxes_count=500)

//              ╔════════════════════════════════╗              //
//              ║      USER-DEFINED SETTINGS     ║              //
//              ╚════════════════════════════════╝              //

var string smt_settings     = '════════ SMT Divergence ════════'
var string fvg_settings     = '════════ FVG Detection ════════'
var string sweep_settings   = '════════ Liquidity Sweeps ════════'
var string htf_settings     = '════════ HTF Bias ════════'
var string session_settings = '════════ Session Filter ════════'
var string score_settings   = '════════ A+ Scoring ════════'
var string visual_settings  = '════════ Visualization ════════'

tooltip_smt_sym   = 'The correlated instrument for SMT divergence detection.\nFor NQ/MNQ, use ES/MES. For ES/MES, use NQ/MNQ.\nSMT divergence fires when one instrument makes a new swing high/low but the correlated instrument fails to confirm.'
tooltip_smt_look  = 'Number of bars to look back when comparing swing highs/lows between the two instruments. Higher values catch larger divergences but may lag.'
tooltip_sweep     = 'Number of bars to look back when identifying previous swing highs/lows that price has swept through. A sweep occurs when price briefly exceeds a prior high/low then reverses.'
tooltip_sweep_rec = 'How many recent bars to check for any liquidity sweep. If a sweep occurred within this window, the "Liquidity Sweep" condition is marked as met.'
tooltip_htf_tf    = 'Higher timeframe used to determine directional bias. Price above the HTF swing high = bullish bias, below HTF swing low = bearish bias. Common choices: 240 (4H) for intraday, D for swing.'
tooltip_htf_swing = 'Number of HTF bars used to find the swing high/low range for bias determination.'
tooltip_min_score = 'Minimum A+ score required before a signal label appears on the chart. Lower values show more signals, higher values filter to only the strongest setups.'
tooltip_max_zones = 'Maximum number of FVG, IFVG, and OB boxes displayed on the chart. Older zones are removed as new ones appear. Lower values reduce visual clutter.'

i_smtSymbol    = input.symbol("ES1!",  "SMT Symbol",            group=smt_settings,     tooltip=tooltip_smt_sym)
i_smtLookback  = input.int(10,         "SMT Lookback",          group=smt_settings,     tooltip=tooltip_smt_look,  minval=3,  maxval=50)

i_sweepLookback = input.int(20,        "Sweep Lookback",        group=sweep_settings,   tooltip=tooltip_sweep,     minval=5,  maxval=100)
i_sweepRecent   = input.int(5,         "Recent Sweep Window",   group=sweep_settings,   tooltip=tooltip_sweep_rec, minval=2,  maxval=20)

i_htfTF         = input.timeframe("240", "HTF Timeframe",       group=htf_settings,     tooltip=tooltip_htf_tf)
i_htfSwingLen   = input.int(10,          "HTF Swing Length",     group=htf_settings,     tooltip=tooltip_htf_swing, minval=3,  maxval=50)

i_scoreThreshold = input.int(40,  "Min Score for Label",        group=score_settings,   tooltip=tooltip_min_score, minval=0,  maxval=100)

i_showFVG     = input.bool(true,  "Show FVG Zones",             group=visual_settings)
i_showIFVG    = input.bool(true,  "Show IFVG Zones",            group=visual_settings)
i_showOB      = input.bool(true,  "Show Order Blocks",          group=visual_settings)
i_showSweeps  = input.bool(true,  "Show Sweep Markers",         group=visual_settings)
i_showSession = input.bool(true,  "Show Session Background",    group=visual_settings)
i_showScore   = input.bool(true,  "Show Score Labels",          group=visual_settings)
i_showDash    = input.bool(true,  "Show Dashboard Table",       group=visual_settings)
i_maxZones    = input.int(5,      "Max Zones Displayed",        group=visual_settings,  tooltip=tooltip_max_zones, minval=1,  maxval=20)

var string color_settings = '════════ Colors ════════'
i_bullFVG   = input.color(color.new(#26a69a, 80), "Bullish FVG",  group=color_settings)
i_bearFVG   = input.color(color.new(#ef5350, 80), "Bearish FVG",  group=color_settings)
i_ifvgCol   = input.color(color.new(#ff9800, 80), "IFVG Zone",    group=color_settings)
i_bullOB    = input.color(color.new(#2196f3, 85), "Bullish OB",   group=color_settings)
i_bearOB    = input.color(color.new(#9c27b0, 85), "Bearish OB",   group=color_settings)
i_bslCol    = input.color(color.new(#ff5722, 0),  "BSL Sweep",    group=color_settings)
i_sslCol    = input.color(color.new(#4caf50, 0),  "SSL Sweep",    group=color_settings)

//              ╔════════════════════════════════╗              //
//              ║        FVG DETECTION           ║              //
//              ╚════════════════════════════════╝              //

// Bullish FVG: gap up — bar[1] low > bar[2] high
bool bullFVG    = low[1] > high[2]
float bullFVGhi = bullFVG ? math.min(high[2], high[0]) : na
float bullFVGlo = bullFVG ? low[1] : na

// Bearish FVG: gap down — bar[1] high < bar[2] low
bool bearFVG    = high[1] < low[2]
float bearFVGhi = bearFVG ? high[1] : na
float bearFVGlo = bearFVG ? math.max(low[2], low[0]) : na

bool hasFVG     = bullFVG or bearFVG
bool fvgIsBull  = bullFVG

// Track latest FVG for scoring
var float lastFVGhi   = na
var float lastFVGlo   = na
var bool  lastFVGbull = false

if bullFVG
    lastFVGhi   := bullFVGhi
    lastFVGlo   := bullFVGlo
    lastFVGbull := true
if bearFVG
    lastFVGhi   := bearFVGhi
    lastFVGlo   := bearFVGlo
    lastFVGbull := false

// Draw FVG boxes
var box[] fvgBoxArr = array.new_box()

if i_showFVG and bullFVG
    if array.size(fvgBoxArr) >= i_maxZones
        box.delete(array.shift(fvgBoxArr))
    array.push(fvgBoxArr, box.new(bar_index[1], bullFVGlo, bar_index + 10, bullFVGhi,
         border_color=color.new(#26a69a, 60), bgcolor=i_bullFVG,
         text="FVG ▲", text_size=size.tiny, text_color=color.new(#26a69a, 30)))

if i_showFVG and bearFVG
    if array.size(fvgBoxArr) >= i_maxZones
        box.delete(array.shift(fvgBoxArr))
    array.push(fvgBoxArr, box.new(bar_index[1], bearFVGlo, bar_index + 10, bearFVGhi,
         border_color=color.new(#ef5350, 60), bgcolor=i_bearFVG,
         text="FVG ▼", text_size=size.tiny, text_color=color.new(#ef5350, 30)))

//              ╔════════════════════════════════╗              //
//              ║        IFVG DETECTION          ║              //
//              ╚════════════════════════════════╝              //

var bool  prevFVGexists = false
var bool  prevFVGbull   = false
var float prevFVGhi     = na
var float prevFVGlo     = na

bool hasIFVG     = false
bool ifvgIsBull  = false
float ifvgHi     = na
float ifvgLo     = na

if hasFVG
    float curHi = fvgIsBull ? bullFVGhi : bearFVGhi
    float curLo = fvgIsBull ? bullFVGlo : bearFVGlo

    if prevFVGexists and (fvgIsBull != prevFVGbull)
        hasIFVG    := true
        ifvgIsBull := not fvgIsBull
        ifvgHi     := math.min(curHi, prevFVGhi)
        ifvgLo     := math.max(curLo, prevFVGlo)

    prevFVGexists := true
    prevFVGbull   := fvgIsBull
    prevFVGhi     := curHi
    prevFVGlo     := curLo

// Draw IFVG boxes
var box[] ifvgBoxArr = array.new_box()

if i_showIFVG and hasIFVG and not na(ifvgHi) and not na(ifvgLo) and ifvgHi > ifvgLo
    if array.size(ifvgBoxArr) >= i_maxZones
        box.delete(array.shift(ifvgBoxArr))
    array.push(ifvgBoxArr, box.new(bar_index, ifvgLo, bar_index + 10, ifvgHi,
         border_color=color.new(#ff9800, 50), border_style=line.style_dashed, bgcolor=i_ifvgCol,
         text="IFVG", text_size=size.tiny, text_color=color.new(#ff9800, 20)))

//              ╔════════════════════════════════╗              //
//              ║      LIQUIDITY SWEEPS          ║              //
//              ╚════════════════════════════════╝              //

float prevSwingHi = ta.highest(high, i_sweepLookback)[1]
float prevSwingLo = ta.lowest(low, i_sweepLookback)[1]

bool bslSweep = high > prevSwingHi
bool sslSweep = low  < prevSwingLo

// Check if any sweep in recent N bars
bool recentSweep = false
for j = 0 to i_sweepRecent - 1
    if high[j] > ta.highest(high, i_sweepLookback)[j + 1]
        recentSweep := true
        break
    if low[j] < ta.lowest(low, i_sweepLookback)[j + 1]
        recentSweep := true
        break

// Draw sweep markers
if i_showSweeps and bslSweep
    label.new(bar_index, high, "BSL",
         style=label.style_triangledown, color=i_bslCol, textcolor=color.white, size=size.tiny)
if i_showSweeps and sslSweep
    label.new(bar_index, low, "SSL",
         style=label.style_triangleup, color=i_sslCol, textcolor=color.white, size=size.tiny)

//              ╔════════════════════════════════╗              //
//              ║       ORDER BLOCKS             ║              //
//              ╚════════════════════════════════╝              //

// Bullish OB: bullish candle preceded by bearish candle
bool isBullOB = close > open and close[1] < open[1]
// Bearish OB: bearish candle preceded by bullish candle
bool isBearOB = close < open and close[1] > open[1]

// Check OB-FVG overlap (scan recent OBs against latest FVG)
bool obOverlap = false
if hasFVG
    for k = 1 to 50
        if k > bar_index
            break
        bool wasBullOB_k = close[k] > open[k] and close[k+1] < open[k+1]
        bool wasBearOB_k = close[k] < open[k] and close[k+1] > open[k+1]
        if fvgIsBull and wasBullOB_k
            if high[k] >= lastFVGlo and low[k] <= lastFVGhi
                obOverlap := true
                break
        if not fvgIsBull and wasBearOB_k
            if high[k] >= lastFVGlo and low[k] <= lastFVGhi
                obOverlap := true
                break

// Draw OB boxes
var box[] obBoxArr = array.new_box()

if i_showOB and isBullOB
    if array.size(obBoxArr) >= i_maxZones
        box.delete(array.shift(obBoxArr))
    array.push(obBoxArr, box.new(bar_index, low, bar_index + 8, high,
         border_color=color.new(#2196f3, 50), border_style=line.style_dotted, bgcolor=i_bullOB,
         text="OB ▲", text_size=size.tiny, text_color=color.new(#2196f3, 30)))

if i_showOB and isBearOB
    if array.size(obBoxArr) >= i_maxZones
        box.delete(array.shift(obBoxArr))
    array.push(obBoxArr, box.new(bar_index, low, bar_index + 8, high,
         border_color=color.new(#9c27b0, 50), border_style=line.style_dotted, bgcolor=i_bearOB,
         text="OB ▼", text_size=size.tiny, text_color=color.new(#9c27b0, 30)))

//              ╔════════════════════════════════╗              //
//              ║          HTF BIAS              ║              //
//              ╚════════════════════════════════╝              //

htfSwingHi = request.security(syminfo.tickerid, i_htfTF, ta.highest(high, i_htfSwingLen)[1], lookahead=barmerge.lookahead_on)
htfSwingLo = request.security(syminfo.tickerid, i_htfTF, ta.lowest(low, i_htfSwingLen)[1],   lookahead=barmerge.lookahead_on)
htfClose   = request.security(syminfo.tickerid, i_htfTF, close[1],                            lookahead=barmerge.lookahead_on)

bool htfBullish = htfClose > htfSwingHi
bool htfBearish = htfClose < htfSwingLo
bool htfAligned = htfBullish or htfBearish

//              ╔════════════════════════════════╗              //
//              ║       SMT DIVERGENCE           ║              //
//              ╚════════════════════════════════╝              //

// This symbol: is current bar the swing high/low of the lookback?
float thisHighest = ta.highest(high, i_smtLookback)
float thisLowest  = ta.lowest(low, i_smtLookback)
bool  thisNewHigh = high >= thisHighest
bool  thisNewLow  = low  <= thisLowest

// SMT symbol: same check
smtNewHigh = request.security(i_smtSymbol, timeframe.period, high >= ta.highest(high, i_smtLookback))
smtNewLow  = request.security(i_smtSymbol, timeframe.period, low  <= ta.lowest(low, i_smtLookback))

// Divergence: one makes new extreme, the other doesn't
bool smtBullDiv  = thisNewLow  and not smtNewLow    // this sweeps low, SMT holds = bullish
bool smtBearDiv  = thisNewHigh and not smtNewHigh   // this sweeps high, SMT holds = bearish
bool smtDiv      = smtBullDiv or smtBearDiv

//              ╔════════════════════════════════╗              //
//              ║       SESSION FILTER           ║              //
//              ╚════════════════════════════════╝              //

int utcH = hour(time, "UTC")

bool isAsia    = utcH >= 0  and utcH < 8
bool isLondon  = utcH >= 8  and utcH < 16
bool isNY      = utcH >= 13 and utcH < 21
bool isOverlap = isLondon and isNY

int sessionPts = isOverlap ? 10 : isNY ? 10 : isLondon ? 8 : isAsia ? 5 : 0

string sessionName = isOverlap ? "Overlap" : isNY ? "NY" : isLondon ? "London" : isAsia ? "Asia" : "Off"

color sessionBG = isOverlap ? color.new(#ffeb3b, 95) :
     isNY      ? color.new(#2196f3, 95) :
     isLondon  ? color.new(#4caf50, 95) :
     isAsia    ? color.new(#9c27b0, 95) : na

bgcolor(i_showSession ? sessionBG : na, title="Session")

//              ╔════════════════════════════════╗              //
//              ║        A+ SCORING              ║              //
//              ╚════════════════════════════════╝              //

int score = 0
score += hasFVG      ? 20 : 0
score += hasIFVG     ? 10 : 0
score += htfAligned  ? 20 : 0
score += recentSweep ? 15 : 0
score += obOverlap   ? 15 : 0
score += smtDiv      ? 10 : 0
score += sessionPts
score := math.min(score, 100)

string grade = score >= 80 ? "A+" : score >= 60 ? "A" : score >= 40 ? "B" : score >= 20 ? "C" : "D"

color gradeCol = score >= 80 ? color.new(#00e676, 0) :
     score >= 60 ? color.new(#26a69a, 0) :
     score >= 40 ? color.new(#ffeb3b, 0) :
     score >= 20 ? color.new(#ff9800, 0) :
     color.new(#ef5350, 0)

// Signal labels on chart
if i_showScore and hasFVG and score >= i_scoreThreshold
    float atrOff = ta.atr(14) * 0.5
    float yPos   = fvgIsBull ? low - atrOff : high + atrOff
    var label.style lStyle = label.style_label_up

    string tipText = "── " + grade + " Signal (" + str.tostring(score) + "/100) ──" +
         "\nFVG: " + (hasFVG ? "✅ " + (fvgIsBull ? "Bullish" : "Bearish") : "❌") +
         "\nIFVG: " + (hasIFVG ? "✅" : "❌") +
         "\nHTF Bias: " + (htfBullish ? "✅ Bullish" : htfBearish ? "✅ Bearish" : "❌ Neutral") +
         "\nLiq Sweep: " + (recentSweep ? "✅" : "❌") +
         "\nOB Overlap: " + (obOverlap ? "✅" : "❌") +
         "\nSMT Div: " + (smtDiv ? "✅" : "❌") +
         "\nSession: " + sessionName + " (+" + str.tostring(sessionPts) + ")"

    label.new(bar_index, yPos,
         grade + " (" + str.tostring(score) + ")",
         style=fvgIsBull ? label.style_label_up : label.style_label_down,
         color=gradeCol, textcolor=color.white, size=size.normal,
         tooltip=tipText)

//              ╔════════════════════════════════╗              //
//              ║        DASHBOARD TABLE         ║              //
//              ╚════════════════════════════════╝              //

var table dash = table.new(position.top_right, 2, 9,
     bgcolor=color.new(#1e1e1e, 10), border_width=1, border_color=color.new(#333333, 0))

if barstate.islast and i_showDash
    string ck = "✅"
    string no = "❌"

    table.cell(dash, 0, 0, "A+ Score",       text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 0, grade + " (" + str.tostring(score) + ")", text_color=gradeCol, text_size=size.small)

    table.cell(dash, 0, 1, "Session",         text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 1, sessionName,        text_color=color.white, text_size=size.tiny)

    table.cell(dash, 0, 2, "HTF Bias",        text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 2, htfBullish ? ck + " Bull" : htfBearish ? ck + " Bear" : no + " Neutral",
         text_color=color.white, text_size=size.tiny)

    table.cell(dash, 0, 3, "FVG",             text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 3, hasFVG ? ck + (fvgIsBull ? " Bull" : " Bear") : no,
         text_color=color.white, text_size=size.tiny)

    table.cell(dash, 0, 4, "IFVG",            text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 4, hasIFVG ? ck : no, text_color=color.white, text_size=size.tiny)

    table.cell(dash, 0, 5, "Liq Sweep",       text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 5, recentSweep ? ck : no, text_color=color.white, text_size=size.tiny)

    table.cell(dash, 0, 6, "OB-FVG Overlap",  text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 6, obOverlap ? ck : no, text_color=color.white, text_size=size.tiny)

    table.cell(dash, 0, 7, "SMT Divergence",  text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 7, smtDiv ? ck : no,  text_color=color.white, text_size=size.tiny)

    table.cell(dash, 0, 8, "SMT Symbol",      text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 8, i_smtSymbol,        text_color=color.white, text_size=size.tiny)

//              ╔════════════════════════════════╗              //
//              ║            ALERTS              ║              //
//              ╚════════════════════════════════╝              //

alertcondition(hasFVG and score >= 80, "A+ Signal (80+)",  "A+ Signal! Score: {{score}}")
alertcondition(hasFVG and score >= 60, "A Signal (60+)",   "A Signal detected. Score: {{score}}")
alertcondition(hasFVG and score >= 40, "B+ Signal (40+)",  "B+ Signal detected. Score: {{score}}")
alertcondition(bslSweep,               "BSL Sweep",        "Buy-side liquidity sweep detected")
alertcondition(sslSweep,               "SSL Sweep",        "Sell-side liquidity sweep detected")
alertcondition(smtDiv,                 "SMT Divergence",   "SMT Divergence detected")
